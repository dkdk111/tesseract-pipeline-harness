# Agent working area: keep the folder and its README, ignore run outputs.
.tesseract/*
!.tesseract/README.md

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Operator profile: a durable artifact, not a run output — keep it tracked.
!.tesseract/operator-profile/
!.tesseract/operator-profile/**
